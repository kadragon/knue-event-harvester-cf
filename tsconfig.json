{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "@types/node",
      "@types/better-sqlite3",
      "vitest/globals"
    ]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
