{
  "name": "knue-event-harvester",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:coverage:ui": "vitest --run --coverage --reporter=html",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.9",
    "better-sqlite3": "^11.9.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "lefthook": "^2.1.5",
    "tsx": "^4.16.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.0.16"
  }
}
